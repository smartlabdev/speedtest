# ── Speedtest Server — Konfigurasjon ──────────────────────────────────────
# Kopier denne filen til config.env og juster verdiene.
# Start med: docker-compose --env-file config/config.env up -d

# Port serveren lytter på (inne i containeren)
PORT=8080

# Maks tillatt filstørrelse for nedlasting/opplasting (MB)
MAX_SIZE_MB=100

# Visningsnavn på serveren (vises i web-UI og /speedtest/status)
SERVER_NAME=Heimnett SpeedTest
